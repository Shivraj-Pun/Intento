# ---------------------------------------------------------------------------
# Bundled runtime environment template for Ask Blinkit (Intento).
#
# Copy this file to `Environment.env` in the SAME folder. That copy is bundled
# into the app and read at launch by AppConfig via DotEnvEnvironment.
# `Environment.env` is git-ignored so real keys never get committed.
#
#   cp Environment.env.example Environment.env
#
# ---------------------------------------------------------------------------
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
USE_MOCK_SERVICES=true
CURRENCY_CODE=INR
LOCALE_IDENTIFIER=en_IN
