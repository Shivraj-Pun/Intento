# ---------------------------------------------------------------------------
# Ask Blinkit (Intento) — environment template
#
# Copy this file to `.env` (both at the repo root and bundled in the app —
# see README) and fill in real values. The real `.env` is git-ignored.
#
# Format: KEY=VALUE, one per line. `#` starts a comment. Values may be quoted.
# ---------------------------------------------------------------------------

# LLM provider used for natural-language intent extraction.
# Supported (Phase 2): openai | anthropic | gemini | mock
LLM_PROVIDER=openai

# API key for the chosen provider. Leave blank to force the on-device mock
# extractor (the app still runs fully without a key).
LLM_API_KEY=

# Base URL of the LLM API (override for Azure/OpenAI-compatible gateways).
LLM_BASE_URL=https://api.openai.com/v1

# Model identifier to request.
LLM_MODEL=gpt-4o-mini

# When true, wire up local mock data sources instead of live network services.
# Set to false in Phase 2 once a real backend/LLM key is configured.
USE_MOCK_SERVICES=true

# Locale / currency used for price formatting.
CURRENCY_CODE=INR
LOCALE_IDENTIFIER=en_IN
