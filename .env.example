# Ask Intento environment template.
# Copy to `.env` (repo root) and to Intento/Intento/Resources/Environment.env.
# Real files are git-ignored; only *.example templates are committed.

# LLM provider: gemini | openai | anthropic | mock
LLM_PROVIDER=gemini

# API key for the provider. Leave blank to run on the built-in on-device
# mock extractor (the app works fully without a key).
LLM_API_KEY=

# Base URL for the provider API.
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Model identifier.
LLM_MODEL=gemini-2.0-flash

# true = use local mock data services. Set false once a key/backend is wired.
USE_MOCK_SERVICES=true

CURRENCY_CODE=INR
LOCALE_IDENTIFIER=en_IN
