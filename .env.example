# Ask Intento environment template.
# Copy to `.env` (repo root) and to Intento/Intento/Resources/Environment.env.
# Real files are git-ignored; only *.example templates are committed.

# LLM provider: apple | gemini | openai | anthropic | mock
# "apple" uses on-device Apple Foundation Models (iOS 26+, no API key needed).
# "gemini" uses Gemini cloud API (requires LLM_API_KEY).
LLM_PROVIDER=apple

# API key for cloud providers (gemini/openai/anthropic).
# Not needed when LLM_PROVIDER=apple (on-device inference).
LLM_API_KEY=

# Base URL for cloud provider API (only used with gemini/openai/anthropic).
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Model identifier (only used with cloud providers).
LLM_MODEL=gemini-2.0-flash

# true = use local mock data services. false = use real intent extraction.
USE_MOCK_SERVICES=false

CURRENCY_CODE=INR
LOCALE_IDENTIFIER=en_IN
